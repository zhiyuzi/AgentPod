# === AgentPod 服务配置 ===
AGENTPOD_DATA_DIR=./data
AGENTPOD_HOST=0.0.0.0
AGENTPOD_PORT=8000
AGENTPOD_MAX_CONCURRENT=20
AGENTPOD_SHUTDOWN_TIMEOUT=30
AGENTPOD_LOG_LEVEL=debug

# === Admin API 鉴权 ===
AGENTPOD_ADMIN_KEY=

# === 共享层（可选，data/shared 存在即自动启用）===
# AGENTPOD_SHARED_DIR=data/shared

# === 定时任务（Cron）===
# AGENTPOD_CRON_ENABLED=true
# AGENTPOD_CRON_MAX_CONCURRENT=5
# AGENTPOD_CRON_TICK_INTERVAL=60
# AGENTPOD_CRON_SYNC_INTERVAL=300

# === 火山引擎（主测试 Provider）===
VOLCENGINE_API_KEY=19c31a26-23f7-4d39-b98e-562622ccff4c
VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

